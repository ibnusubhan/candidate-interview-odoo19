<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_candidate_tree" model="ir.ui.view">
        <field name="name">candidate.interview.tree</field>
        <field name="model">candidate.interview</field>
        <field name="arch" type="xml">
            <list>
                <field name="candidate_code"/>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="position"/>
                <field name="status"/>
            </list>
        </field>
    </record>

        <!-- Kanban View -->
    <record id="view_candidate_kanban" model="ir.ui.view">
        <field name="name">candidate.interview.kanban</field>
        <field name="model">candidate.interview</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">

                <field name="candidate_code"/>
                <field name="name"/>
                <field name="position"/>
                <field name="status"/>

                <templates>

                    <t t-name="card">

                        <div class="oe_kanban_global_click">

                            <strong>
                                <field name="candidate_code"/>
                            </strong>

                            <br/>

                            <field name="name"/>

                            <br/>

                            <small>
                                <field name="position"/>
                            </small>

                        </div>

                    </t>

                </templates>

            </kanban>
        </field>
    </record>

    <!-- Graph View -->
<record id="view_candidate_graph" model="ir.ui.view">
    <field name="name">candidate.interview.graph</field>
    <field name="model">candidate.interview</field>
    <field name="arch" type="xml">

        <graph string="Candidate Statistics" type="bar">

            <field name="status"/>

        </graph>

    </field>
</record>

    <!-- Form View -->
    <record id="view_candidate_form" model="ir.ui.view">
        <field name="name">candidate.interview.form</field>
        <field name="model">candidate.interview</field>
        <field name="arch" type="xml">
            <form string="Candidate Interview">

    <header>

        <button
            name="action_screening"
            string="Screening"
            type="object"
            class="btn-primary"/>

        <button
            name="action_interview"
            string="Interview"
            type="object"
            class="btn-primary"/>

        <button
            name="action_accept"
            string="Accept"
            type="object"
            class="btn-success"/>

        <button
            name="action_reject"
            string="Reject"
            type="object"
            class="btn-danger"/>

        <field
            name="status"
            widget="statusbar"
            statusbar_visible="draft,screening,interview,accepted,rejected"/>

    </header>

    <sheet>


                    <group>
                        <field name="candidate_code" readonly="1"/>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="position"/>
                    </group>

                    <group>
                        <field name="experience"/>
                        <field name="expected_salary"/>
                        <field name="interview_date"/>
                        <field name="interview_time"/>
                    </group>

                    <group>
                        <field name="notes"/>
                    </group>

                </sheet>

            </form>
        </field>
    </record>

<!-- Search View -->
<record id="view_candidate_search" model="ir.ui.view">
    <field name="name">candidate.interview.search</field>
    <field name="model">candidate.interview</field>
    <field name="arch" type="xml">
        <search string="Search Candidates">

            <!-- Search Field -->
            <field name="candidate_code"/>
            <field name="name"/>
            <field name="email"/>
            <field name="position"/>

            <!-- Filter -->

            <filter string="Draft"
                    name="draft"
                    domain="[('status','=','draft')]"/>

            <filter string="Screening"
                    name="screening"
                    domain="[('status','=','screening')]"/>

            <filter string="Interview"
                    name="interview"
                    domain="[('status','=','interview')]"/>

            <filter string="Accepted"
                    name="accepted"
                    domain="[('status','=','accepted')]"/>

            <filter string="Rejected"
                    name="rejected"
                    domain="[('status','=','rejected')]"/>

            <!-- Group By -->
         <group>

    <filter
        string="Status"
        name="group_status"
        context="{'group_by':'status'}"/>

    <filter
        string="Position"
        name="group_position"
        context="{'group_by':'position'}"/>

</group>

        </search>
    </field>
</record>

<!-- Action -->
<record id="action_candidate_interview" model="ir.actions.act_window">
    <field name="name">Candidates</field>
    <field name="res_model">candidate.interview</field>
    <field name="view_mode">kanban,list,form,graph</field>
    <field name="search_view_id" ref="view_candidate_search"/>
</record>

    <!-- Menu -->
    <menuitem
        id="menu_candidate_root"
        name="Recruitment"/>

    <menuitem
        id="menu_candidate"
        name="Candidates"
        parent="menu_candidate_root"
        action="action_candidate_interview"/>

</odoo>
<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_candidate_tree" model="ir.ui.view">
        <field name="name">candidate.interview.tree</field>
        <field name="model">candidate.interview</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="position"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_candidate_form" model="ir.ui.view">
        <field name="name">candidate.interview.form</field>
        <field name="model">candidate.interview</field>
        <field name="arch" type="xml">
            <form string="Candidate Interview">

                <sheet>

                    <group>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="position"/>
                    </group>

                    <group>
                        <field name="experience"/>
                        <field name="expected_salary"/>
                        <field name="interview_date"/>
                        <field name="interview_time"/>
                        <field name="status"/>
                    </group>

                    <group>
                        <field name="notes"/>
                    </group>

                </sheet>

            </form>
        </field>
    </record>

<!-- Search View -->
<record id="view_candidate_search" model="ir.ui.view">
    <field name="name">candidate.interview.search</field>
    <field name="model">candidate.interview</field>
    <field name="arch" type="xml">

        <search>

            <field name="name"/>
            <field name="email"/>
            <field name="position"/>

            <separator/>

            <filter
                name="draft"
                string="Draft"
                domain="[('status','=','draft')]"/>

            <filter
                name="screening"
                string="Screening"
                domain="[('status','=','screening')]"/>

            <filter
                name="interview"
                string="Interview"
                domain="[('status','=','interview')]"/>

            <filter
                name="accepted"
                string="Accepted"
                domain="[('status','=','accepted')]"/>

            <filter
                name="rejected"
                string="Rejected"
                domain="[('status','=','rejected')]"/>

            <group expand="0" string="Group By">

                <filter
                    string="Status"
                    name="group_status"
                    context="{'group_by':'status'}"/>

            </group>

        </search>

    </field>
</record>


 <!-- Action -->
<record id="action_candidate_interview" model="ir.actions.act_window">
    <field name="name">Candidates</field>
    <field name="res_model">candidate.interview</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="view_candidate_search"/>
</record>
    <!-- Menu -->
    <menuitem
        id="menu_candidate_root"
        name="Recruitment"/>

    <menuitem
        id="menu_candidate"
        name="Candidates"
        parent="menu_candidate_root"
        action="action_candidate_interview"/>

</odoo>